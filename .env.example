# Network Configuration
# Set to 80 for production or 3000 for local development
PORT=

# Environment Configuration
NODE_ENV=

# Primary database connection string for MongoDB Atlas
# Ensure the user has readWrite permissions on the target database
MONGO_URI=

# Defines the depth of log output. 
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=

# Random long strings used to sign and verify JWTs. Keep these private!
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Use zeit/ms format (e.g., 15m, 1h, 7d) or numeric milliseconds
ACCESS_TOKEN_EXPIRY=
REFRESH_TOKEN_EXPIRY=